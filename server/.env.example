# --- OpenAI (required) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# --- Supabase (required for accounts / sessions / reports) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_SECRET_KEY=sb_secret_xxx           # server-side only (service role)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx # safe for the browser (anon)
SUPABASE_DB_PASSWORD=your-db-password

# --- CORS (optional) ---
# Extra browser origins allowed to call the API (comma-separated).
# The three live app URLs + localhost are always allowed. Add PassGP/Kajabi domains here.
ALLOWED_ORIGINS=https://app.passgp.com,https://your-site.kajabi.com

# --- Analytics export API (optional, for Power BI direct pull) ---
# Set a secret key, then pull: GET /api/analytics/export?key=THIS_KEY  (CSV)
# or with header  x-api-key: THIS_KEY   (add &format=json for JSON)
ANALYTICS_API_KEY=set-a-long-random-string

# --- Email (candidate PDF reports via SMTP / nodemailer) ---
# The mailbox the reports are sent FROM, and its app password.
Owner_Email=admin@passgp.au
App_Password=your-mailbox-app-password
# SMTP host/port — defaults to Zoho AU (smtp.zoho.com.au:465). Override if needed:
# SMTP_HOST=smtp.zoho.com.au
# SMTP_PORT=465
# SMTP_SECURE=true
# EMAIL_BCC_OWNER=true   # also send a copy of each report to Owner_Email
